{
	"name": "@mercuryworkshop/proxy-bootstrap",
	"version": "0.0.5",
	"type": "module",
	"packageManager": "pnpm@10.12.1",
	"main": "./dist/bootstrap-server.js",
	"types": "./dist/types/typesEntry.d.ts",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/MercuryWorkshop/scramjet.git",
		"directory": "packages/bootstrap"
	},
	"scripts": {
		"build": "cd ../.. && rspack build --mode production --configName scramjet-bootstrap",
		"prepack": "pnpm build",
		"prepublishOnly": "npx only-allow pnpm",
		"pub": "pnpm publish --no-git-checks --access public"
	},
	"dependencies": {
		"@mercuryworkshop/wisp-js": "catalog:",
		"tar": "^7.5.1"
	},
	"devDependencies": {
		"@mercuryworkshop/epoxy-transport": "catalog:",
		"@mercuryworkshop/libcurl-transport": "catalog:",
		"@mercuryworkshop/proxy-transports": "catalog:",
		"@mercuryworkshop/scramjet-controller": "workspace:*"
	},
	"files": [
		"dist"
	]
}
