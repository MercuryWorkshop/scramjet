{
	"name": "create-proxy-app",
	"version": "0.0.4",
	"description": "Scaffold a Scramjet or Ultraviolet proxy app",
	"type": "module",
	"packageManager": "pnpm@10.12.1",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MercuryWorkshop/scramjet.git",
		"directory": "packages/create-proxy-app"
	},
	"bin": {
		"create-proxy-app": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "cd ../.. && rspack build --mode production --configName create-proxy-app",
		"prepack": "pnpm run build",
		"prepublishOnly": "npx only-allow pnpm",
		"pub": "pnpm publish --no-git-checks --access public"
	},
	"devDependencies": {
		"@types/node": "^26.0.1"
	},
	"dependencies": {
		"@clack/core": "^0.3.4",
		"@clack/prompts": "^0.7.0",
		"ajv": "^8.13.0",
		"chalk": "^5.3.0",
		"commander": "^12.0.0",
		"execa": "^9.1.0",
		"fs-extra": "^11.2.0",
		"giget": "^1.2.3",
		"sort-package-json": "^2.10.0"
	}
}
